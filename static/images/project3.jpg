<svg xmlns="http://www.w3.org/2000/svg" width="400" height="250" viewBox="0 0 400 250">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#FFC107;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7C3AED;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="400" height="250" fill="#111827"/>
  <rect x="0" y="0" width="400" height="250" fill="url(#grad)" fill-opacity="0.2"/>
  <text x="200" y="125" font-family="Arial, sans-serif" font-size="24" fill="#FFFFFF" text-anchor="middle" dominant-baseline="middle">Blog Platform</text>
  <text x="200" y="150" font-family="Arial, sans-serif" font-size="12" fill="#9CA3AF" text-anchor="middle">Project Preview</text>
</svg>