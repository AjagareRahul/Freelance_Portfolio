# Django Secret Key - IMPORTANT: Change this in production!
# Generate a secure key using: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Debug mode - Set to False in production
DEBUG=False

# Allowed hosts (comma-separated)
# For Render: use the RENDER_EXTERNAL_HOSTNAME environment variable
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.onrender.com

# Database URL (for production on Render, this will be provided automatically)
# Example: postgresql://user:password@hostname:5432/dbname
DATABASE_URL=

# Render external hostname (set automatically by Render)
RENDER_EXTERNAL_HOSTNAME=

# =============================================================================
# Superuser Configuration for Django Admin
# =============================================================================
# These are used during deployment to automatically create a superuser
# IMPORTANT: Remove these values after first successful login for security!
# Set these only in Render environment variables, NOT in .env file
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your-secure-password-here
